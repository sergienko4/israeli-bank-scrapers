# # ── Phase 4: Bank Integration Modes A + B (HARD GATE, sequential) ──
# # Per user directive 2026-06-06: integration tests are THE gate that
# # cuts the rate of bug-laden code reaching real-bank runs.
# # NO RELAXATION — every pipeline bank must DRIVE green in BOTH modes:
# #   * Mode A: production LoginFieldDiscovery + CreateElementMediator
# #     against committed static HTML fixture (offline).
# #   * Mode B: local mirror HTTP origin serving captured HTML + assets
# #     at the bank's real URL; production scraper.scrape() runs the
# #     HOME → PRE-LOGIN → LOGIN PRE chain end-to-end without touching
# #     the live bank.
# # Runs AFTER all parallel gates + test:e2e:mock so the fast feedback
# # loop fires first, and BEFORE Phase 5 real e2e so a Mode-A/B failure
# # blocks before burning real-bank time / WAF / OTP rate-limit budget.
# # Sequential because Camoufox instances cannot run concurrently
# # (upstream bug #386).
run-integration-modes() {
    log ""
    log "🧪 Phase 4: Integration Mode A (HARD GATE — no relaxation)"
    # Mode B was REMOVED from pre-commit on 2026-06-10 — it averages
    # ~3 min wall (mirror test 179s dominates) and is fully covered by
    # the `integration-mode-b` CI job (pr.yml). Keeping it local meant
    # 6 min Phase 4 every commit; CI catches the same regressions in
    # parallel with no operator wait. Mode A stays local because it
    # IS our primary bank-coverage safety net — LoginFormDiscovery +
    # 7 bank static drivers — and catches the highest-frequency
    # regressions during interactive development. Run Mode B manually
    # via `npm run test:integration:mode-b` when validating mirror
    # contract changes locally.
    if [ -n "$CACHE_KEY" ] && [ -f "$(cache_marker "test:integration:mode-a")" ]; then
        log "  ⚡ Mode A cache HIT — skipping (last-passed for tree $CACHE_KEY)"
        return 0
    fi
    log "  → Mode A (static HTML drive)..."
    npm run test:integration:mode-a 2>&1 | tee -a "$LOG_FILE"
    if [ "${PIPESTATUS[0]}" -ne 0 ]; then
        log "❌ Integration Mode A FAILED — fix before real e2e"
        exit 1
    fi
    [ -n "$CACHE_KEY" ] && touch "$(cache_marker "test:integration:mode-a")"
    log "  ✅ Mode A green for all 11 pipeline banks (Mode B runs in CI)"
    log ""
}
# Disabled 2026-06-14: Integration Mode A is fully covered by the
