#!/bin/sh
LOG_FILE=".pre-commit-output.log"
: > "$LOG_FILE"

run_gate() {
  "$@" 2>&1 | tee -a "$LOG_FILE"
  return "${PIPESTATUS[0]}"
}

echo "" | tee -a "$LOG_FILE"
echo "🛑  MANDATORY QUALITY GATE" | tee -a "$LOG_FILE"
echo "══════════════════════════════════════════════════════" | tee -a "$LOG_FILE"
echo "  Rules: no any · explicit return types · ≤20 lines/fn" | tee -a "$LOG_FILE"
echo "  · ≤300 lines/file · ≤3 params · complexity ≤10" | tee -a "$LOG_FILE"
echo "  See CLEAN_CODE.md for fix strategies" | tee -a "$LOG_FILE"
echo "══════════════════════════════════════════════════════" | tee -a "$LOG_FILE"

echo "" | tee -a "$LOG_FILE"
echo "🔍  [1/8] Type check — strict, no implicit any..." | tee -a "$LOG_FILE"
run_gate npx tsc --noEmit || exit 1

echo "" | tee -a "$LOG_FILE"
echo "🧪  [2/8] Unit tests (with coverage thresholds — same as CI)..." | tee -a "$LOG_FILE"
run_gate npm run test:unit --coverage || exit 1

echo "" | tee -a "$LOG_FILE"
echo "🎭  [3/8] Mocked E2E tests..." | tee -a "$LOG_FILE"
run_gate npm run test:e2e:mock --no-coverage || exit 1

echo "" | tee -a "$LOG_FILE"
echo "🧹  [4/8] Lint + format (CI parity)..." | tee -a "$LOG_FILE"
run_gate npx lint-staged || exit 1
echo "  → ESLint all src/ (matches CI: npx eslint src --max-warnings 0)..." | tee -a "$LOG_FILE"
run_gate npx eslint src --max-warnings 0 || exit 1
echo "  → Prettier full check (matches CI scope)..." | tee -a "$LOG_FILE"
run_gate npx prettier --check "src/**/*.{ts,tsx,js,jsx,json,md}" || exit 1

echo "" | tee -a "$LOG_FILE"
echo "📦  [5/8] Build verification (tsup + publint)..." | tee -a "$LOG_FILE"
run_gate npx tsup || exit 1
npx rimraf lib/Common lib/Scrapers lib/Tests
test -f lib/Index.cjs && test -f lib/Index.mjs && test -f lib/Index.d.ts && test -f lib/Index.d.mts || { echo "❌ Build output missing" | tee -a "$LOG_FILE"; exit 1; }
run_gate npm run check-exports || exit 1

echo "" | tee -a "$LOG_FILE"
echo "🔒  [6/8] npm audit (production deps)..." | tee -a "$LOG_FILE"
run_gate npm audit --audit-level=high --omit=dev || exit 1

echo "" | tee -a "$LOG_FILE"
echo "🏦  [7/8] Real E2E — non-OTP banks (Amex, Isracard, Max, Discount, VisaCal)..." | tee -a "$LOG_FILE"
if [ -f .env ]; then
  npx ncp src/Tests/.tests-config.tpl.js src/Tests/.tests-config.js 2>/dev/null
  run_gate npx jest --no-coverage --testPathIgnorePatterns='/node_modules/' --testPathIgnorePatterns='E2eMocked' \
    --testPathPatterns='E2eReal/Amex|E2eReal/Isracard|E2eReal/Max|E2eReal/Discount|E2eReal/Visacal' \
    --verbose || exit 1
else
  echo "  ⚠️  No .env file — skipping real E2E (CI will run them)" | tee -a "$LOG_FILE"
fi

echo "" | tee -a "$LOG_FILE"
echo "🔎  [8/8] Dependency review (informational)..." | tee -a "$LOG_FILE"
run_gate npm audit --audit-level=high 2>/dev/null || true

echo "" | tee -a "$LOG_FILE"
echo "══════════════════════════════════════════════════════" | tee -a "$LOG_FILE"
echo "✅  ALL 8 GATES PASSED. COMMITTING..." | tee -a "$LOG_FILE"
echo "" | tee -a "$LOG_FILE"
