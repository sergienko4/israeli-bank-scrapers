# Bank credentials for E2E tests
# Copy this file to .env and fill in real values
# NEVER commit the .env file — it is gitignored

# ── Logging ───────────────────────────────────────────────────────
# LOG_LEVEL: pino level (trace | debug | info | warn | error). Default 'info'.
# LOG_PATH:  base directory for per-bank log files. When set, the pipeline
#            writes JSON-line logs to <LOG_PATH>/<bank>/run-<timestamp>.log
#            (one file per scrape). When unset, no file logging happens —
#            stdout-only. Single source of truth: NO manual setup in test
#            harness or scraper code.
# LOG_LEVEL=trace
# LOG_PATH=c:/tmp/log/

# Amex (American Express Israel)
AMEX_ID=
AMEX_CARD6DIGITS=
AMEX_PASSWORD=

# VisaCal
VISACAL_USERNAME=
VISACAL_PASSWORD=

# Discount Bank
DISCOUNT_ID=
DISCOUNT_PASSWORD=
DISCOUNT_NUM=

# OneZero (deferred — requires SMS OTP strategy)
# ONEZERO_EMAIL=
# ONEZERO_PASSWORD=
# ONEZERO_PHONE_NUMBER=
