# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Typescript v1 declaration files
typings/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env

# NPM package build output
lib/

# Claude Code (local only)
CLAUDE.md
.claude/

# IDEs
.idea
.vscode
.DS_Store
.beinleumi-otp.tmp
.onezero-otp.tmp
# TypeDoc output (regenerated via `npm run docs`; deployed to GH Pages /api/)
/typedoc-build/
# mkdocs build output (regenerated via `python -m mkdocs build`; deployed to GH Pages /)
/site/
/.mkdocs-strict-out/

# Local debug sessions, trace output, inspection scripts — never commit
# All local work lives in local-debug/ (debug captures + scripts)
local-debug/
.visacal-debug/

# Local-only reproduction harnesses (e.g. Amex slow-network login repro).
# Real-credential probes that must NEVER reach the PR or coverage gates.
src/Tests/**/*.local.test.ts

# Future bank scraper backlog (local research — not part of current PR)
capture/
tasks/

scripts/**
!scripts/audit-fixtures-pii.cjs
!scripts/check-staged-pii.cjs
!scripts/pii-denylist.sha256
!scripts/sweep-fixtures-pii.ts
!scripts/validate-pr-body.mjs

# Stale lint-output left by an older verify-script version. Current
# src/Scrapers/Pipeline/EslintCanaries/verify.sh writes to os.tmpdir(),
# so this in-repo path must never appear again.
.canary-verify-tmp.json

#Understand Anything local data (local research — not part of current PR)
.understand-anything
# Python bytecode (mkdocs hooks)
__pycache__/
*.pyc

.agent-*/*
.commit*

# Operator-specific PII literals consumed at runtime by
# scripts/audit-fixtures-pii.cjs and src/Tests/Integration/Tools/PiiRedactor.ts.
# Copy .pii-secrets.example.json → .pii-secrets.json and populate with REAL
# values for your environment. NEVER commit the real file — it contains
# operator name, account numbers, IDs, emails, etc. The example file with
# placeholder values IS committed so tests have a default to load from.
.pii-secrets.json
.pii-secrets.local.json
