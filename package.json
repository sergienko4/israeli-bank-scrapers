{
  "name": "@sergienko4/israeli-bank-scrapers",
  "version": "7.8.1",
  "description": "Provide scrapers for all major Israeli banks and credit card companies",
  "engines": {
    "node": ">= 22.14.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "commonjs",
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.cjs"
      }
    }
  },
  "scripts": {
    "clean": "rimraf lib",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns=E2eReal --testPathIgnorePatterns=E2eMocked",
    "test:e2e:mock": "jest --testPathIgnorePatterns=/node_modules/ --testPathIgnorePatterns=E2eReal --testPathPatterns=E2eMocked",
    "test:e2e:real": "jest --testPathIgnorePatterns=/node_modules/ --testPathIgnorePatterns=E2eMocked --testPathPatterns=E2eReal",
    "test:ci": "ncp src/Tests/.tests-config.tpl.js src/Tests/.tests-config.js && jest --ci --coverage",
    "validate:all": "npm run type-check && npm run test:unit && npm run test:e2e:mock && npm run lint",
    "check-exports": "publint",
    "lint": "eslint src --max-warnings 0 && npm run format:check",
    "lint:fix": "eslint src --fix && npm run format",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "dev": "npm run type-check -- --watch",
    "build": "npm run lint && tsup",
    "postbuild": "rimraf lib/Common lib/Scrapers lib/Tests",
    "prepare:default": "git reset --hard && npm ci && npm run build",
    "prepare": "tsup && rimraf lib/Common lib/Scrapers lib/Tests",
    "reset": "git reset --hard && npm ci",
    "docs": "typedoc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sergienko4/israeli-bank-scrapers.git"
  },
  "keywords": ["israel", "israeli bank", "israeli bank scraper"],
  "author": "Elad Shaham",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sergienko4/israeli-bank-scrapers/issues"
  },
  "homepage": "https://github.com/sergienko4/israeli-bank-scrapers#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.3.0",
    "@json2csv/plainjs": "^7.0.6",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/source-map-support": "^0.5.10",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fast-check": "^4.5.3",
    "fs-extra": "^11.3.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.0",
    "minimist": "^1.2.8",
    "ncp": "^2.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "publint": "^0.3.17",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@hieutran094/camoufox-js": "^0.6.8",
    "lodash": "^4.17.23",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "pino": "^10.3.1",
    "playwright": "^1.58.2",
    "utility-types": "^3.11.0",
    "uuid": "^11.1.0"
  },
  "files": ["lib/**/*"],
  "overrides": {
    "test-exclude": "^7.0.2",
    "ua-parser-js": "1.0.41"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": ["eslint --fix --max-warnings 0", "prettier --write"],
    "*.json": ["prettier --parser json --write"],
    "*.md": ["prettier --parser markdown --write"]
  }
}
